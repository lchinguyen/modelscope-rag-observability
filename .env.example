# =========================
# Google Gemini API
# =========================

# Create at:
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional model override
GEMINI_MODEL=gemini-2.5-flash


# =========================
# Arize Phoenix Cloud
# =========================

# Create Phoenix API key at:
# https://app.phoenix.arize.com
PHOENIX_API_KEY=your_phoenix_api_key_here

# Must include your Phoenix space:
# Example:
# https://app.phoenix.arize.com/s/my-team-space
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space-name

PHOENIX_PROJECT_NAME=gemini-hackathon